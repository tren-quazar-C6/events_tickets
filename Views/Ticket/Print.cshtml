@model events_tickets.Models.Sale
@{
    ViewData["Title"] = "Tickets";
}

<div class="no-print d-flex justify-content-between align-items-center mb-3">
    <h4>Sale #@Model.Id — @Model.EventName</h4>
    <div>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary me-2">← Dashboard</a>
        <button onclick="window.print()" class="btn btn-primary">🖨 Print again</button>
    </div>
</div>

<div class="no-print mb-3">
    <div class="alert alert-success">
        Sale completed. <strong>@Model.Tickets.Count ticket(s)</strong>
        sent to <strong>@Model.Customer.Email</strong>. Printing now...
    </div>
</div>

@foreach (var ticket in Model.Tickets)
{
    <div class="border rounded p-3 mb-3" style="page-break-inside: avoid;">
        <div class="row align-items-center">
            <div class="col-8">
                <h5 class="mb-1">@ticket.EventName</h5>
                <p class="mb-1 text-muted">@ticket.EventDate.ToString("dddd, MMM dd yyyy — HH:mm")</p>
                <hr class="my-2" />
                <p class="mb-1"><strong>@ticket.CustomerName</strong></p>
                @if (!string.IsNullOrEmpty(ticket.SeatInfo))
                {
                    <p class="mb-1">Seat: <strong>@ticket.SeatInfo</strong></p>
                }
                <p class="mb-0 text-muted" style="font-size:0.8rem;">
                    Code: <strong>@ticket.Code</strong>
                </p>
            </div>
            <div class="col-4 text-center">
                @if (!string.IsNullOrEmpty(ticket.QrCode))
                {
                    <img src="data:image/png;base64,@ticket.QrCode"
                         alt="QR" style="width:100px;height:100px;" />
                }
                <div class="mt-1 fw-bold">$@ticket.Price.ToString("N2")</div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        window.addEventListener('load', function () { window.print(); });
    </script>
}