@model events_tickets.Models.SaleViewModel
@{
    ViewData["Title"] = "Sell Tickets";
}

<div class="row">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header bg-dark text-white">Event</div>
            <div class="card-body">
                @if (Model.Evento != null)
                {
                    <h5>@Model.Evento.NombreEvento</h5>
                    <p class="mb-1"><strong>Date:</strong> @Model.Evento.FechaEvento.ToString("MMM dd, yyyy HH:mm")</p>
                    <p class="mb-1"><strong>Type:</strong> @Model.Evento.TipoEvento</p>
                    <p class="mb-0">
                        <strong>Available:</strong>
                        <span class="badge bg-success">@Model.Evento.AsientosDisponibles seats</span>
                    </p>
                }
            </div>
        </div>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary w-100">← Back</a>
    </div>

    <div class="col-md-8">
        <form asp-action="Store" method="post">
            <input type="hidden" asp-for="EventoId" />
            <input type="hidden" name="asientosJson" id="asientosJson" value="[]" />

            <div class="card mb-3">
                <div class="card-header bg-dark text-white">
                    Select Seats
                    <span class="badge bg-warning text-dark ms-2" id="selectedCount">0 selected</span>
                </div>
                <div class="card-body">
                    @if (!Model.AsientosDisponibles.Any())
                    {
                        <p class="text-muted">No seats available.</p>
                    }
                    else
                    {
                        @foreach (var zona in Model.AsientosDisponibles.GroupBy(a => a.Zona))
                        {
                            <p class="mb-1"><strong>@zona.Key</strong></p>
                            <div class="d-flex flex-wrap gap-1 mb-3">
                                @foreach (var asiento in zona)
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary seat-btn"
                                            data-id="@asiento.IdEventoAsiento"
                                            data-precio="@asiento.Precio"
                                            title="@asiento.CodigoAsiento — $@asiento.Precio.ToString("N2")">
                                        @asiento.CodigoAsiento
                                    </button>
                                }
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="card mb-3">
                <div class="card-header bg-dark text-white">Customer</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CustomerName" class="form-label">Full name *</label>
                            <input asp-for="CustomerName" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CustomerDocument" class="form-label">Document / ID *</label>
                            <input asp-for="CustomerDocument" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CustomerEmail" class="form-label">Email *</label>
                            <input asp-for="CustomerEmail" type="email" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="CustomerPhone" class="form-label">Phone</label>
                            <input asp-for="CustomerPhone" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-3 no-print" id="totalCard" style="display:none!important;">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <span>Total: <strong id="totalLabel">$0.00</strong></span>
                    <button type="submit" class="btn btn-success">Confirm sale & print</button>
                </div>
            </div>
            <div id="totalCardVisible" style="display:none">
                <div class="card mb-3">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <span>Total: <strong id="totalLabel2">$0.00</strong></span>
                        <button type="submit" class="btn btn-success">Confirm sale & print</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const selected = new Map(); // idEventoAsiento -> precio

        document.querySelectorAll('.seat-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                const id = parseInt(this.dataset.id);
                const precio = parseFloat(this.dataset.precio);

                if (selected.has(id)) {
                    selected.delete(id);
                    this.classList.remove('btn-primary');
                    this.classList.add('btn-outline-secondary');
                } else {
                    selected.set(id, precio);
                    this.classList.remove('btn-outline-secondary');
                    this.classList.add('btn-primary');
                }

                const count = selected.size;
                const total = [...selected.values()].reduce((a, b) => a + b, 0);

                document.getElementById('selectedCount').textContent = count + ' selected';
                document.getElementById('asientosJson').value = JSON.stringify([...selected.keys()]);

                const totalText = '$' + total.toFixed(2);
                document.getElementById('totalLabel2').textContent = totalText;

                const cardVisible = document.getElementById('totalCardVisible');
                cardVisible.style.display = count > 0 ? 'block' : 'none';
            });
        });
    </script>
}